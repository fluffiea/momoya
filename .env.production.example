# ─────────────────────────────────────────────────────────────────────────────
# Momoya 生产部署环境变量样板
#
# 用法：
#   cp .env.production.example .env.production
#   随后用 openssl rand -hex 32 生成两个不同的随机串分别填入下面两个密钥
# ─────────────────────────────────────────────────────────────────────────────

# Express session 签名密钥；务必长随机串（建议 ≥32 字节十六进制）
# 生成方法：openssl rand -hex 32
SESSION_SECRET=

# 资料字段（displayName / bio）AES-256-GCM 加密密钥
# 生成方法：openssl rand -hex 32
PROFILE_SECRET_KEY=

# ── 预构建镜像（GitHub Actions → GHCR）────────────────────────────────────────
# 与仓库 Packages 里名称一致：ghcr.io/<GitHub 用户名小写>
# 例：你的 GitHub 是 MyName → 填 ghcr.io/myname
MOMOYA_IMAGE_PREFIX=ghcr.io/your-github-username-lowercase

# 一般用 latest；回滚到某一版时可改为 CI 打的完整 commit SHA（40 位）
MOMOYA_IMAGE_TAG=latest
