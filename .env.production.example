# ─────────────────────────────────────────────────────────────────────────────
# Momoya 生产部署环境变量样板
#
# 用法：
#   cp .env.production.example .env.production
#   随后用 openssl rand -hex 32 生成两个不同的随机串分别填入下面两个密钥
# ─────────────────────────────────────────────────────────────────────────────

# Express session 签名密钥；务必长随机串（建议 ≥32 字节十六进制）
# 生成方法：openssl rand -hex 32
SESSION_SECRET=

# 资料字段（displayName / bio）AES-256-GCM 加密密钥
# 生成方法：openssl rand -hex 32
PROFILE_SECRET_KEY=

# 对外暴露的 Web 端口；默认 8080，常见配合上游 Caddy/Cloudflare 走 443
WEB_PORT=8080
