# 本机开发 @momoya/server 用。复制为同目录 .env 后按需修改。
# 生产 Docker 使用仓库根 .env.docker.example。

# 服务
NODE_ENV=development
PORT=3000

# MongoDB：默认连接 `pnpm docker:dev:up` 暴露的本机 mongo（无账密）。
MONGODB_URI=mongodb://127.0.0.1:27017/momoya

# 生产容器示例；本机开发不要启用。
# MONGODB_URI=mongodb://momoya_app:密码@mongo:27017/momoya?authSource=momoya

# Redis：后端启动时必连；默认连接 dev compose 暴露的 6379。
REDIS_URL=redis://127.0.0.1:6379

# JWT：access / refresh 须为不同强随机串。
JWT_ACCESS_SECRET=please-change-me-to-a-random-string-of-at-least-32-chars
JWT_ACCESS_TTL=2h
JWT_REFRESH_SECRET=please-change-me-to-another-random-string-of-at-least-32-chars
JWT_REFRESH_TTL=14d

# 上传：本地写入 ./uploads，并通过 /static 暴露。
UPLOAD_DIR=./uploads
STATIC_BASE_URL=http://localhost:3000/static
UPLOAD_MAX_SIZE_BYTES=5242880

# Swagger：未设置时非 production 开、production 关。
# UI: http://localhost:3000/api/docs  OpenAPI: /api/docs-json
# SWAGGER_ENABLED=true
# SWAGGER_PATH=api/docs
