# Taro development 构建期变量。个人差异写入 .env.development.local（不提交）。
# 优先级：.env.development.local > .env.development > .env.local > .env

# HTTP API：模拟器可用 127.0.0.1；真机改为开发机局域网 IPv4。
TARO_APP_DEV_API_HOST=127.0.0.1
TARO_APP_DEV_API_PORT=3000

# WebSocket / Socket.IO 根。空 = 与 API 同 origin；变量必须声明，供 Taro 构建期替换。
TARO_APP_WS_URL=
