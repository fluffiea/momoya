# 生产 Docker 环境变量。复制为仓库根 .env.docker 后填真实值：
#   docker compose --env-file .env.docker -f docker-compose.prod.yml build
#   docker compose --env-file .env.docker -f docker-compose.prod.yml up -d

# MongoDB：仅空数据卷首次初始化时生效；已有数据改密需手动 db.updateUser 或重建卷。
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=please-change-me-root-password
MOMOYA_APP_USERNAME=momoya_app
MOMOYA_APP_PASSWORD=please-change-me-app-password

# JWT：access / refresh 使用不同的强随机串。
JWT_ACCESS_SECRET=please-change-me-to-a-random-string-of-at-least-32-chars
JWT_ACCESS_TTL=2h
JWT_REFRESH_SECRET=please-change-me-to-another-random-string-of-at-least-32-chars
JWT_REFRESH_TTL=14d

# 上传与静态资源：STATIC_BASE_URL 须与 Nginx 对外 HTTPS 地址一致。
STATIC_BASE_URL=https://api.momoya.store/static
UPLOAD_MAX_SIZE_BYTES=5242880

# 服务：SERVER_PORT 只绑定宿主机 127.0.0.1，由同机 Nginx 反代。
SERVER_PORT=3000
MOMOYA_SERVER_TAG=latest

# Swagger：生产默认关闭；仅内网联调需要时打开。
# SWAGGER_ENABLED=false
