{
  "name": "momoya",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm --filter @momoya/shared run build && concurrently -n web,api -c blue,green \"pnpm --filter @momoya/web dev\" \"pnpm --filter @momoya/api dev\"",
    "dev:web": "pnpm --filter @momoya/web dev",
    "dev:api": "pnpm --filter @momoya/api dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "preview": "pnpm --filter @momoya/web preview",
    "commit": "git-cz",
    "cm": "git add . && pnpm run commit",
    "seed": "pnpm --filter @momoya/api seed"
  },
  "packageManager": "pnpm@10.30.1",
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "commitizen": "^4.3.1",
    "concurrently": "^9.1.2",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
