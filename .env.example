# 复制为 .env 后按需填写（勿提交 .env）

# 前端（生产构建）：API 根地址，勿尾斜杠；本地开发留空即可走 Vite 代理
# VITE_API_BASE_URL=https://your-api.example.com

# MongoDB（本地 Docker 默认）
MONGODB_URI=mongodb://127.0.0.1:27017/momoya

# 会话密钥（生产务必更换长随机串）
SESSION_SECRET=replace-with-long-random-string

# 资料字段加密（displayName、bio）用 AES-256-GCM；留空则本地明文存库。生产环境必填
PROFILE_SECRET_KEY=

# API 端口
PORT=4000

# 首次 seed 两个固定账号的初始密码（仅 seed 使用）
SEED_PASSWORD_JIANGJIANG=
SEED_PASSWORD_MENGMENG=
