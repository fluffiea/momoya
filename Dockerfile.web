# syntax=docker/dockerfile:1.7
# ─────────────────────────────────────────────────────────────────────────────
# Momoya Web 镜像（Vite 静态产物 + nginx 托管）
#
# 关键点：
# 1. 不传 VITE_API_BASE_URL：前端走相对路径 /api，由 nginx 反代到 api 容器，
#    这样同源 cookie 自动生效，省去 CORS 配置。
# 2. SPA 单入口：try_files $uri /index.html
# 3. assets/* 是带 hash 的文件，长缓存；index.html 不缓存。
# ─────────────────────────────────────────────────────────────────────────────

ARG NODE_VERSION=20
FROM node:${NODE_VERSION}-bookworm-slim AS builder
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable && corepack prepare pnpm@10.30.1 --activate
WORKDIR /repo

COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY apps/web/package.json apps/web/
COPY packages/shared/package.json packages/shared/

RUN --mount=type=cache,id=pnpm-store,target=/pnpm/store \
    pnpm install --frozen-lockfile

COPY tsconfig*.json ./
COPY packages/shared packages/shared
COPY apps/web apps/web

RUN pnpm --filter @momoya/web run build

# ── runtime：nginx 静态托管 ────────────────────────────────────────────────────
FROM nginx:1.27-alpine AS runtime

# 直接覆盖 nginx 默认配置
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /repo/apps/web/dist /usr/share/nginx/html

EXPOSE 80
